# StudentSuccessOS Environment Variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/studentsuccessos

# Authentication
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here

# OAuth Providers
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# LMS Integrations
# CANVAS_API_KEY=your-canvas-api-key
# CLEVER_CLIENT_ID=your-clever-client-id
# CLEVER_CLIENT_SECRET=your-clever-client-secret

# AI/ML Services (for advanced recommendations)
# OPENAI_API_KEY=your-openai-api-key

# Analytics
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
